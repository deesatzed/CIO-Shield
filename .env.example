# Core paths
COGNITIVEIO_HOME=.cognitiveio

# Runtime mode flags
COGNITIVEIO_ENABLE_APPLE_FM=0
COGNITIVEIO_ENABLE_AB=1
COGNITIVEIO_ARB_VARIANT=
COGNITIVEIO_ENABLE_SOFT_AUTO=0
COGNITIVEIO_IDLE_PAUSE_MS=300

# Hotkeys
COGNITIVEIO_PANIC_HOTKEY=ctrl+option+p
COGNITIVEIO_UNDO_HOTKEY=ctrl+option+z

# Encryption + secure resolution
COGNITIVEIO_DB_ENCRYPTION=optional
COGNITIVEIO_DB_KEY_REF={{SECRET:COGNITIVEIO_DB_KEY}}
COGNITIVEIO_SECRET_CACHE_TTL_SECONDS=60

# Env-backed secret provider values (examples only)
COGNITIVEIO_SECRET_COGNITIVEIO_DB_KEY=replace-me
COGNITIVEIO_SECRET_STRIPE_API_KEY=replace-me
COGNITIVEIO_SECRET_OPENAI_API_KEY=replace-me

# Optional live integration markers
COGNITIVEIO_ENABLE_LIVE_FM_TESTS=0
COGNITIVEIO_ENABLE_LIVE_MAC_TESTS=0
