<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  LaunchDaemon for CIO-II Shield Privileged Audit Helper.
  Deployed by corporate MDM to /Library/LaunchDaemons/
  Runs as root to maintain append-only audit file ownership.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.cognitiveio.audit</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Library/PrivilegedHelperTools/com.cognitiveio.audit-helper</string>
    </array>
    <key>RunAtLoad</key>
    <false/>
    <key>KeepAlive</key>
    <false/>
    <key>StandardErrorPath</key>
    <string>/Library/Application Support/CognitiveIO/logs/audit-helper.err</string>
</dict>
</plist>
